# ============================================================
# Wings Global Trade — Environment Variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Contenedor Compartido — member identity token signing (server-only) ---
# HMAC secret for member session tokens (shared-container workspace access).
# If absent, falls back to SUPABASE_SERVICE_ROLE_KEY. Set a distinct random
# value in production so rotating the service key doesn't invalidate members.
CONTAINER_TOKEN_SECRET=

# --- Anthropic (Claude API) — server-side only, never expose to client ---
ANTHROPIC_API_KEY=

# --- Mister operational constants ---
# Model used for Mister v2 conversations (claude-sonnet-4-6)
MISTER_MODEL=claude-sonnet-4-6
# The WhatsApp number Mister surfaces for human escalation (injected into every context block)
MISTER_OPS_WHATSAPP=+50760250735

# --- Upstash Redis (rate limiting for /api/mister) ---
# Get from https://console.upstash.com — create a Redis database
# If absent, rate limiting fails open (Mister still works, no per-IP limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Resend (transactional email) ---
RESEND_API_KEY=

# --- Twilio (WhatsApp API) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_TO=+50760250735

# --- Wings Ops recipients ---
WINGS_OPS_WHATSAPP=+50760250735
WINGS_OPS_EMAIL=
