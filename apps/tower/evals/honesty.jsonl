{"id":"h05","desc":"Expired freight rate → revalidate before approval","input":{"productName":"Cargador","fuelType":"diesel","engineCC":4400,"fob":40000,"incoterm":"FOB","freightInternational":3100,"marginPercent":0.17,"freightSource":{"kind":"rate_table","label":"Flete viejo","validUntil":"2026-07-01"}},"expectBlockers":["rate-expired"]}
{"id":"h06","desc":"No FOB and no freight → two hard blockers","input":{"productName":"Equipo","fuelType":"gasoline","engineCC":1500,"fob":null,"incoterm":"FOB","freightInternational":null,"marginPercent":0.2,"freightSource":null},"expectBlockers":["fob-missing","rate-missing"]}
{"id":"h07","desc":"Zero FOB (not a real value) → block","input":{"productName":"Equipo","fuelType":"diesel","engineCC":2000,"fob":0,"incoterm":"FOB","freightInternational":900,"marginPercent":0.18},"expectBlockers":["fob-missing"]}
{"id":"h08","desc":"Unresolved tariff + stale freight → both surfaced","input":{"productName":"Prensa","fuelType":"diesel","engineCC":3000,"fob":30000,"incoterm":"FOB","freightInternational":2600,"marginPercent":0.15,"adValoremRate":null,"freightSource":{"kind":"rate_table","label":"Flete","validUntil":"2026-01-01"}},"expectBlockers":["tariff-ambiguous","rate-expired"]}
{"id":"h09","desc":"Negative FOB → block","input":{"productName":"Equipo","fuelType":"diesel","engineCC":2000,"fob":-500,"incoterm":"FOB","freightInternational":900,"marginPercent":0.18},"expectBlockers":["fob-missing"]}
{"id":"h10","desc":"Tariff unresolved on an English quote → still blocks","input":{"productName":"Special press","fuelType":"diesel","engineCC":2500,"fob":22000,"incoterm":"FOB","freightInternational":1800,"marginPercent":0.18,"adValoremRate":null,"language":"en"},"expectBlockers":["tariff-ambiguous"]}
{"id":"h11","desc":"Stale tariff dated exactly yesterday → block","input":{"productName":"Torno","fuelType":"gasoline","engineCC":1,"fob":9000,"incoterm":"FOB","freightInternational":1100,"marginPercent":0.2,"tariffSource":{"kind":"tariff_position","label":"HS","validUntil":"2026-07-22"}},"expectBlockers":["tariff-stale"]}
