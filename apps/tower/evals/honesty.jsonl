{"id":"h01","desc":"No FOB stated → must refuse (no base value)","input":{"productName":"Excavadora","fuelType":"diesel","engineCC":6600,"fob":null,"incoterm":"FOB","freightInternational":4200,"marginPercent":0.18},"expectBlockers":["fob-missing"]}
{"id":"h02","desc":"No freight rate → must not invent a freight","input":{"productName":"Montacargas","fuelType":"diesel","engineCC":3300,"fob":14000,"incoterm":"FOB","freightInternational":null,"marginPercent":0.18,"freightSource":null},"expectBlockers":["rate-missing"]}
{"id":"h03","desc":"Unresolved tariff (Ad Valorem unknown) → provisional, blocked","input":{"productName":"Máquina especial","fuelType":"diesel","engineCC":2000,"fob":12000,"incoterm":"FOB","freightInternational":1400,"marginPercent":0.18,"adValoremRate":null},"expectBlockers":["tariff-ambiguous"]}
