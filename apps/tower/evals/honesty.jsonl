{"id":"h13","desc":"CIF quote with unresolved tariff → provisional blocked","input":{"productName":"Refrigeración","fuelType":"diesel","engineCC":1,"fob":18000,"incoterm":"CIF","freightInternational":0,"marginPercent":0.13,"adValoremRate":null},"expectBlockers":["tariff-ambiguous"]}
