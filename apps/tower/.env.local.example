# TOWER — environment template. Copy to apps/tower/.env.local and fill in.
# NEVER commit real secrets. `.env*.local` and `.env` are gitignored at the repo root.
# For Vercel, set these in Project → Settings → Environment Variables (same keys).

# ── Supabase (wings-global-trade project pyznlglvwihosemqkhtq · schema `tower`) ──
# Public — safe to expose to the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=https://pyznlglvwihosemqkhtq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server ONLY — bypasses RLS. Never import into a client component. REQUIRED for
# media uploads (signed URLs) and the analytics event emitter.
SUPABASE_SERVICE_ROLE_KEY=

# ── Site URL — absolute base for promo listing / share-card (OG) URLs ──
# e.g. https://tower.wingsglobaltrade.com  (no trailing slash)
NEXT_PUBLIC_SITE_URL=

# ── Tower Intelligence (Claude API) — server only ──
ANTHROPIC_API_KEY=

# ── Import-journey commitment HMAC (server only) — signs/verifies journey tokens ──
JOURNEY_SIGNING_SECRET=

# ── First-party event ingest — per-brand HMAC keys used to verify /api/ingest ──
INGEST_HMAC_KEY_WINGS=
INGEST_HMAC_KEY_ALADIN=

# ── Inbound webhook shared secrets (server only) ──
# Mister hook (/api/hooks/mister) and WhatsApp hook (/api/hooks/whatsapp).
MISTER_HOOK_SECRET=
WHATSAPP_HOOK_SECRET=

# ── Publishing — shared secret for on-demand revalidation webhooks ──
REVALIDATE_SECRET=

# ── n8n — base URL for WhatsApp / doc-gen / digest / rollup pipelines ──
N8N_WEBHOOK_BASE=
